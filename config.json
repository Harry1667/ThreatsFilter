  "scoring": {
    "criteria": {
      "clarity":     { "label": "機會明確度", "desc": "是不是真在找人 / 需求清不清楚", "weight": 20 },
      "skill":       { "label": "能力匹配",   "desc": "種類 + 技能 vs 我會的",        "weight": 25 },
      "competition": { "label": "競爭強度",   "desc": "已被回覆數(紅海)/ 發文新鮮度", "weight": 20 },
      "author":      { "label": "作者品質",   "desc": "粉絲數 / 真客戶 vs 同行",      "weight": 15 },
      "deal":        { "label": "可成交性",   "desc": "像有預算 / 還是只是抱怨",      "weight": 10 },
      "risk":        { "label": "風險訊號",   "desc": "釣魚 / 招代理(分數越高越安全)", "weight": 10 }
    },
    "threshold": 60,
    "maybeThreshold": 45,
    "_note_competition": "貼文回覆數超過此值視為紅海並降級",
    "redOceanReplies": 15,
    "freshHours": 24
  },

  "hardExcludes": {
    "skipDisabledCategories": true,
    "skipRedline": true,
    "skipSkillMatchBelow": 3
  },

  "scrape": {
    "headless": false,
    "maxPostsPerQuery": 30,
    "maxHomeFeed": 40,
    "scrollRounds": 6,
    "delayMsBetween": 2500
  }
}
