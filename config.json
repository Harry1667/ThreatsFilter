    "App開發": { "enabled": true, "keywords": ["app", "手機", "ios", "android", "flutter", "react native"] },
    "AI整合": { "enabled": true, "keywords": ["ai", "gpt", "chatgpt", "claude", "llm", "聊天機器人", "chatbot", "ai 導入", "ai 代理", "生成"] },
    "自動化": { "enabled": true, "keywords": ["自動化", "automation", "n8n", "zapier", "make", "排程", "工作流", "串接", "數位轉型", "複製貼上", "重複作業", "省人力"] },
    "爬蟲資料": { "enabled": true, "keywords": ["爬蟲", "scraping", "抓資料", "data", "excel", "google sheet"] },
    "Bug修復": { "enabled": true, "keywords": ["bug", "修", "壞掉", "報錯", "卡住", "fix"] },
