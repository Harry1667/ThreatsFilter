# 複製成 .env 並填入。.env 已 gitignore。

# ── ProxyCLI（hdw-proxycli）AI 代理（沿用 Upwork 版機制，gRPC via proxy_sdk）──
# 選填：指定 python 直譯器（需 ≥3.7 且裝了 grpcio/protobuf）。留空會自動偵測，
# 避開 macOS 內建死掉的 Python 3.5。例：/opt/homebrew/bin/python3
AI_PROXY_PYTHON=
AI_PROXY_HOST_PORT=cli.twloop.com:443
AI_PROXY_TOKEN=在此填入你的_token
AI_PROXY_PROJECT=threads-filter
AI_PROXY_GROUP=backend

# 深度分析 / 產草稿（高階模型）
AI_PROXY_PROVIDER=claude
AI_PROXY_TIER=high

# 第一道門分類 / triage 快篩（便宜模型，由程式以 opts 覆蓋）
AI_TRIAGE_PROVIDER=openai
AI_TRIAGE_TIER=low

# ── Threads 爬蟲（gstack browse 指紋瀏覽器）──
# 需先在 gstack 視窗登入 Threads；爬蟲會連到同一個 session
THREADS_LOGGED_IN=false

# ── Dashboard ──
WEB_PORT=3013
INGEST_KEY=
